# Copy to .env and fill. NEVER commit .env.
# v1 is SHADOW-ONLY: the only required secret is the Anthropic key.

# --- Required for LLM advisor layer (Phase 3) ---
# Provider is set in config/desk.yaml (llm.provider): openrouter or anthropic.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional: Discord alerts + decision trail ---
DISCORD_WEBHOOK_URL=

# --- NOT NEEDED IN v1 (shadow mode has no trading credential). ---
# Only populate after Gate C (micro-live) and the venue admission checklist.
# Hyperliquid agent-wallet key (NOT your main wallet key; no withdrawal rights):
# HYPERLIQUID_AGENT_PRIVATE_KEY=
# HYPERLIQUID_MAIN_WALLET_ADDRESS=
